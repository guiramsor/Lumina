# Credenciales del proyecto de Supabase para sincronizar la posicion de escucha.
# Copia este archivo como .env.local y rellena los dos valores. Sin ellos,
# Lumina funciona igual pero solo en local, sin sincronizacion.
#
# Los encuentras en tu proyecto de Supabase: Project Settings > API
#   - Project URL      -> VITE_SUPABASE_URL
#   - anon / public key -> VITE_SUPABASE_ANON_KEY
#
# La clave anon es publica por diseno: lo que protege los datos es la politica
# RLS de supabase/schema.sql, que solo deja ver el progreso de tu propia cuenta.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
